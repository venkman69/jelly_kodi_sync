#!/bin/bash
# Launch the FastHTML movie-renamer web UI in the foreground.
# Sources .env / .credentials, then runs `sync-jelly-kodi web`.
# Extra args are passed through, e.g:  ./bin/sync_jelly_kodi_web --port 8080
SCRIPT_DIR=$(dirname "$0")
PROJ_DIR=$(dirname "$SCRIPT_DIR")
cd "$PROJ_DIR" || exit 1

export PATH=$PATH:~/.local/bin
[ -d "$HOME/.local/share/mise/shims" ] && export PATH="$HOME/.local/share/mise/shims:$PATH"

set -a
. "$PROJ_DIR/.env"
[ -f "$PROJ_DIR/.credentials" ] && . "$PROJ_DIR/.credentials"
set +a

exec uv run sync-jelly-kodi web --port "${WEB_PORT:-5001}" --host "${WEB_HOST:-0.0.0.0}" "$@"
