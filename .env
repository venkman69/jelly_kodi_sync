# proj python
LOG_DIR=./logs
LOG_FILE=jelly_kodi_sync.log
LOG_LEVEL=DEBUG

# jelly and kodi configs
JELLYFIN_URL=http://cinema.anikat.lan:8096/ #  add jelly fin api key in .credentials
JELLYFIN_SYNC_USER=venkman # which user to sync with 
# Kodi connection
KODIHOST=192.168.0.133
KODIPORT=8080
# kodi user/pass in .credentials

# 3 parts, first part is the root folder to all media movies and tvshows
#  second is the holder for tv vs movies
# third is the actual path to the file
# first part will be discarded
JELLY_MOUNT_PAT="^(.*/movies/)([^/]+)(.*)"
KODI_MOUNT_PAT="^(.*/movies/)([^/]+)(.*)"

DRY_RUN=false

TRANSCODED=/mnt/movies/TRANSCODED
ARCHIVE=/mnt/movies/RIP
WEB_PORT=8506
